# ─── Qdrant (embedded — runs in-process, no server needed) ──────────────
QDRANT_COLLECTION=estormi

# ─── Embeddings (fastembed ONNX, in-process) ─────────────────────────────
EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBED_DIM=768

# ─── MCP Server ──────────────────────────────────────────────────────────
MCP_SERVER_PORT=8000
# Safe default: loopback only. Set MCP_SERVER_HOST=0.0.0.0 only if you
# understand the implication: any device on the same network reaches the
# server unauthenticated unless ESTORMI_MCP_TOKEN is set and required by your
# client.
MCP_SERVER_HOST=127.0.0.1
# Bearer token for /mcp and /sse. When none is set, a per-launch random token
# is generated automatically and written to DATA_DIR/.mcp_token (chmod 600).
# MCP clients (Claude Desktop, etc.) should read the token from that file.
# To use a fixed token instead: openssl rand -base64 32
# ESTORMI_MCP_TOKEN=
# Also reads MCP_BEARER_TOKEN and MCP_TOKEN (first non-empty wins).

# ─── Network / LAN access (opt-in) ───────────────────────────────────────────
# To expose Estormi on the LAN (e.g. for an MCP client on another machine —
# the iOS companion never talks to the server; it reads the iCloud vault):
#   MCP_SERVER_HOST=0.0.0.0
#   ESTORMI_MCP_TOKEN=$(openssl rand -base64 32)
# Find your local IP (macOS WiFi):  ipconfig getifaddr en0
# Connect from another device:      http://<your-ip>:8000
# WARNING: on untrusted networks, ALWAYS keep ESTORMI_MCP_TOKEN set.

# ─── Repo root (development only) ────────────────────────────────────────────
# Source builds locate the live tree via this env var; otherwise the server
# derives the repo root from the server module's own location (../../.. from
# estormi_server/server/jobs.py), which is the app-bundle resource root in a
# packaged deploy.
# ESTORMI_REPO_ROOT=/path/to/your/Estormi

# ─── Data layout (rarely needed) ─────────────────────────────────────────────
# Default data dir: ~/Library/Application Support/Estormi
# Override the entire data directory (SQLite, Qdrant, logs, vault metadata)
# in one go. The packaged app sets this from its Application Support path.
# ESTORMI_DATA_DIR=

# Override just the SQLite path (defaults to ${ESTORMI_DATA_DIR}/estormi.db).
# Useful for tests that point at a temp DB without touching the rest of the
# data dir. ESTORMI_DB and ESTORMI_DB_PATH are both consumed (ingestion scripts
# read ESTORMI_DB; the server pipeline and engine lock read ESTORMI_DB_PATH).
# ESTORMI_DB=
# ESTORMI_DB_PATH=

# Tauri-set: macOS Application Support path. The shell exports this at
# startup so the bundled sidecar agrees with the SPA on file locations.
# Don't set this by hand.
# ESTORMI_TAURI_SUPPORT_DIR=

# ─── iCloud vault (iOS companion only) ───────────────────────────────────────
# Folder the user picks in the iOS Files app for sync between Mac and phone.
# The Mac writes the daily briefings and an engine-history log here; the
# companion reads them. Default: ~/Library/Mobile Documents/com~apple~CloudDocs/Estormi
# ESTORMI_VAULT_DIR=
# Retention budget (MB) for briefing narration audio (.m4a). Once exceeded, the
# oldest narrations are pruned, newest kept; the dated briefing JSON is always
# kept in full (the local quill trains on the whole history). 0 disables. Default: 500
# ESTORMI_VAULT_MAX_AUDIO_MB=

# ─── Local quill / distillation ──────────────────────────────────────────────
# The QLoRA quill trains on the full briefing archive (every dated JSON in the
# vault, edited or not) — there is no lookback window or reference cap to tune.
# Scratch volume for the fuse/convert step (needs ~40 GB free).
# ESTORMI_DISTILL_WORK_DIR=

# ─── Locale ──────────────────────────────────────────────────────────────────
# Timezone used by the briefing engine when computing day boundaries.
# Defaults to the system zoneinfo; override for testing or for a user whose
# Mac is in a different zone than their daily life (e.g. a traveller).
# ESTORMI_LOCAL_TZ=Europe/Paris

# Comma-separated list of names that mean "you" across your sources, so the
# briefing engine recognises messages and events that involve you. Lets it
# collapse "Alex", "AJ", "Alex Smith" etc. onto a single identity. Default:
# derived from macOS Contacts "Me" + WhatsApp profile name.
# ESTORMI_USER_DISPLAY_NAMES=

# ─── Briefing identity ───────────────────────────────────────────────────────
# Optional name of a partner / second person whose activities appear in your
# sources and should surface in the briefing's correlation threads.
# Consumed by estormi_briefing/runtime.py each run.
# ESTORMI_PARTNER_NAME=

# Override the briefing's scratch directory for fetched articles.
# Default: ${TMPDIR}/estormi-knowledge
# ESTORMI_KNOWLEDGE_TMP_DIR=

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Bearer token the Tauri shell mints once and shares with the FastAPI server
# so the in-app WhatsApp helper can talk to its own Axum endpoint on
# 127.0.0.1:9877. Don't set this by hand — the shell writes it at launch.
# ESTORMI_WA_TOKEN=

# Keep the WhatsApp connection alive even when the Estormi app is in the
# background. Off by default to save battery. Set to true to enable.
# ESTORMI_WHATSAPP_ALWAYS_ON=false

# ─── Test harness (test runs only) ───────────────────────────────────────────
# Override the data dir used by the test suite (defaults to a tmpdir).
# Set ESTORMI_KEEP_TEST_DATA=true to inspect after a failed run.
# ESTORMI_TEST_DATA_DIR=
# ESTORMI_KEEP_TEST_DATA=false
# ESTORMI_TEST_HOST=127.0.0.1
# ESTORMI_TEST_PORT=18000

# ─── Retrieval tuning ────────────────────────────────────────────────────
# Blend: final_score = (1-RECENCY_WEIGHT)·fusion + RECENCY_WEIGHT·decay(age)
# Half-life in days — a chunk this old contributes 0.5 of the full recency.
RECENCY_WEIGHT=0.3
RECENCY_HALF_LIFE_DAYS=180

# ─── Ingestion tuning (overrides per-source defaults) ────────────────────
# Uncomment to override. Units: characters unless noted.
# NOTES_CHUNK_SIZE=900
# MAIL_CHUNK_SIZE=1000

# Per-source lookback windows (days). Defaults sized for the unattended
# nightly DAG; widen for a one-shot backfill.
# IMESSAGE_DAYS_WINDOW=14
# GCAL_DAYS_WINDOW=90

# Staging directory shared between ingestion and the Tauri shell. The
# bundled app sets this; you only need it in dev if your scratch space
# isn't $HOME/estormi-staging.
# STAGING_DIR=

# WhatsApp ingestion thresholds — see estormi_ingestion/whatsapp/ingest_conversations.py
# for what each one does. Defaults work for typical use.
# WHATSAPP_MIN_TEXT_LEN=20
# WHATSAPP_MSG_CHUNK_MSGS=12
# WHATSAPP_MSG_CHUNK_STEP=6
# WHATSAPP_WINDOW_GAP_SECONDS=1800

# ─── Server / client integration ─────────────────────────────────────────
# Where in-repo ingest scripts POST chunks. Defaults to the local server.
# MCP_SERVER_URL=http://localhost:8000

# ─── Briefing engine ────────────────────────────────────────────────────
# ESTORMI_BRIEFING_PROVIDER=local
# ESTORMI_BRIEFING_MODEL=auto
# ESTORMI_BRIEFING_DATE=          # override target date (YYYY-MM-DD)
# ESTORMI_BRIEFING_LANGUAGE=fr    # only "fr" is validated
# Hard wall-clock cap (seconds) for the full briefing pipeline. When
# exceeded between stages, the pipeline ships whatever it has (partial
# briefing). 0 = no cap (default). The existing briefing_time_budget_min
# setting governs best-of-N quality passes within a stage; this cap
# governs the pipeline end-to-end.
# BRIEFING_WALL_CLOCK_BUDGET_S=0

# ─── APNs push (iOS new-briefing alerts) ────────────────────────────────
# ESTORMI_APNS_KEY_ID=
# ESTORMI_APNS_TEAM_ID=
# ESTORMI_APNS_KEY_PATH=          # path to .p8 signing key
# ESTORMI_APNS_TOPIC=app.estormi.ios
# ESTORMI_APNS_USE_SANDBOX=0

# ─── Doorbell (CloudKit push helper) ────────────────────────────────────
# ESTORMI_DOORBELL_HELPER=        # path to the signed helper .app
# ESTORMI_DOORBELL_CONTAINER=iCloud.app.estormi

# ─── Distillation engine (optional QLoRA fine-tune) ─────────────────────
# ESTORMI_DISTILL_WORKSPACE=      # path with ≥40 GB free
# ESTORMI_DISTILL_EPOCHS=3
# ESTORMI_DISTILL_BATCH_SIZE=4

# ─── Documents ingestion ────────────────────────────────────────────────
# DOCUMENTS_ROOT=~/Documents

# ─── Audit ───────────────────────────────────────────────────────────────
# AUDIT_LOG_PATH=~/Library/Application Support/Estormi/audit.log
# AUDIT_LOG_MAX_BYTES=16777216
