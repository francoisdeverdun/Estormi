# Worktree env symlinks (point back at the main checkout; never tracked).
/.venv
/node_modules
/python
/packages/ui-kit/node_modules
/packages/web-ui/node_modules
*.tsbuildinfo
*.egg-info/
.pytest_cache/
.ruff_cache/
.grimp_cache/
