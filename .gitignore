# Coverage JSON is written under build/coverage/ (keep the repo root clean); the
# bare coverage.json entry stays as a backstop for older/ad-hoc invocations.
/build/
coverage.json
coverage_review.json
qa-metrics.json
test-results.xml
.playwright-mcp/
apps/estormi-macos/target/
# Tauri-generated ACL/capability schemas — regenerated by `tauri_build` on every
# build (build.rs), so they are derived output, never a committed source.
apps/estormi-macos/gen/
# Xcode export-options for `xcodebuild -exportArchive` — carries a Team ID and is
# regenerated per machine/signing context; never a committed source.
apps/estormi-ios/ExportOptions.plist
packages/estormi_server/build_version.txt
.claude/worktrees/
# Internal prompt runbooks (leak workflow/paths/SHAs; never tracked).
.claude/prompts/
python/

# Local screenshots from validation runs
/briefing-page*.png

# setuptools build output — regenerated by `python -m build`
packages/memory_core/build/

# Local scheduled-task lock
.claude/scheduled_tasks.lock

# graphify skill — local-only build state. The graph embeds absolute build
# paths and is regenerated on demand with `graphify update .`, so it is not
# committed (it would leak machine-specific paths into the public repo).
graphify-out/

# Nightly guardian reports (local-only)
.nightly/
